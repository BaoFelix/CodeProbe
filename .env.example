# CodeProbe LLM configuration
# Copy this file to .env and fill in your credentials.
# Only needed for the design review step — scanning and the HTML report
# work without any API key.
#
# NEVER commit your real .env (it is already in .gitignore).

# ── Wire format: "openai" (OpenAI-compatible) or "anthropic" ──────
LLM_API_FORMAT=openai

# ── Example A: GitHub Models (free tier, OpenAI-compatible) ───────
LLM_API_URL=https://models.inference.ai.azure.com
LLM_API_KEY=your-github-token-here
LLM_MODEL=gpt-4o

# ── Example B: Anthropic Claude (uncomment to use) ────────────────
# LLM_API_FORMAT=anthropic
# LLM_API_URL=https://api.anthropic.com
# LLM_API_KEY=sk-ant-your-key-here
# LLM_MODEL=claude-sonnet-4-20250514

# ── Optional ──────────────────────────────────────────────────────
# Fallback chain walked automatically on 429 rate limits (comma-separated)
# LLM_FALLBACK_MODELS=gpt-4o,gpt-4o-mini,Meta-Llama-3.1-405B-Instruct,Phi-4

# Set to 1 to bypass the LLM response cache while tuning prompts
# LLM_NO_CACHE=1
